# ─── Telegram Bot ───────────────────────────────────────────
TOKEN=your_bot_token_here
ADMIN_LIST=123456789,987654321

CHANNEL_ID=-1001234567890
CHANNEL_LINK=https://t.me/your_channel

# ─── Payments ────────────────────────────────────────────────
CRYPTO_TOKEN=your_crypto_pay_token
STAR_PAYMENT_TOKEN=your_star_payment_token

# ─── External URLs ───────────────────────────────────────────
RATE_API_URL=https://min-api.cryptocompare.com/data/price
USER_AGREEMENT=https://telegra.ph/your-user-agreement
DELETE_ANIMATION_URL=https://media.giphy.com/media/h3oEjI6SIIHBdRxXI40/giphy.gif

# ─── PostgreSQL ───────────────────────────────────────────────
# Use POSTGRES_DB (not POSTGRES_NAME) — must match the Docker env var
POSTGRES_DB=telegrambot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Django ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_DEBUG=False

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your_strong_admin_password

# ─── Redis ───────────────────────────────────────────────────
# Docker: redis://redis:6379/0  |  Local: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0